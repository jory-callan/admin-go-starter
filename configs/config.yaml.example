# ======================
# 基础日志配置
# ======================
log:
  level: "info"       # 日志级别: debug, info, warn, error, fatal
  format: "json"      # 日志格式: json, text
  output: "stdout"    # 输出目标: stdout, 文件路径（如 /var/log/app.log）
  file_path: "/var/log/app.log" # 日志文件路径，填了就有文件，没有填就没有文件
  max_size: 100       # 单个日志文件最大大小(MB)
  max_backups: 5      # 保留的旧日志文件数量
  max_age: 7          # 旧日志文件保留天数(天)
  compress: true      # 是否压缩旧日志文件

# ======================
# HTTP 服务配置
# ======================
http:
  enable_debug: false
  host: "0.0.0.0" # 监听地址
  port: 8080 # 监听端口
  read_timeout: "10s"   # 读取请求超时时间
  write_timeout: "10s"  # 写入响应超时时间
  idle_timeout: "60s"   # 空闲连接超时时间
  max_header_bytes: "1MB"   # 最大允许的请求头大小 (支持 KB, MB, GB)
  max_body_size: "10MB"   # 最大允许的请求体大小 (支持 KB, MB, GB)
  # CORS 跨域配置
  cors:
    allow_origins: ["https://example.com", "http://localhost:3000"] # 允许的源
    allow_methods: ["GET", "POST", "PUT", "DELETE", "OPTIONS"] # 允许的 HTTP 方法
    allow_headers: ["Content-Type", "Authorization"] # 允许的请求头
    expose_headers: ["X-Request-ID"] # 暴露给客户端的响应头
    max_age: 86400 # 预检请求缓存时间(秒)
  # 限流配置 (可选)
  rate_limit:
    requests_per_second: 100  # 每秒允许的请求数
    burst: 20           # 突发请求允许的最大数量

# ======================
# 数据库配置 (扁平化显式命名)
# ======================
# 核心原则：每个用途明确的数据库都有独立的顶级 Key
database:
  driver: "mysql"
  dsn: "root:password@tcp(127.0.0.1:3306)/main_db?charset=utf8mb4&parseTime=True"
  max_open_conns: 100
  max_idle_conns: 10

# 日志专用数据库 (可选)
# log_database:
#   driver: "mysql"
#   dsn: "root:password@tcp(127.0.0.1:3306)/log_db?charset=utf8mb4&parseTime=True"
#   max_open_conns: 50
#   max_idle_conns: 5

# 分析专用数据库 (可选)
# analytics_database:
#   driver: "sqlite3"
#   dsn: "./data/analytics.db"
#   max_open_conns: 10

# ======================
# Redis 配置 (扁平化显式命名)
# ======================
redis:
  addr: "127.0.0.1:6379"
  password: ""
  db: 0
  pool_size: 100

# 缓存专用 Redis (可选)
# cache_redis:
#   addr: "127.0.0.1:6379"
#   db: 1
#   pool_size: 50

# Session 专用 Redis (可选)
# session_redis:
#   addr: "127.0.0.1:6380"
#   password: "sess_pass"
#   db: 2
#   pool_size: 30

# ======================
# JWT 配置
# ======================
jwt:
  secret: "your-32-char-secret-key-here"
  expires: "24h"    # 24小时过期
  issuer: "myapp"   # 签发者

# ======================
# 消息队列 (Kafka / RabbitMQ)
# ======================
# kafka:
#   brokers: ["127.0.0.1:9092"]
#   topic: "app_events"
#   group_id: "app_consumer"
#   partition: 0
#   offset: "latest"

# rabbitmq:
#   url: "amqp://guest:guest@localhost:5672/"
#   exchange: "app_events"
#   queue: "app_queue"

# ======================
# 服务发现与注册 (如 Consul, Etcd, Nacos)
# ======================
# service_discovery:
#   enabled: true
#   driver: "consul"
#   address: "127.0.0.1:8500"
#   service_name: "my-go-app"
#   service_port: 8080
#   health_check_path: "/health"

